# Ignora todas as pastas de topo por padrao
/*/

# Mantem no Git apenas estas pastas
!/historia/
!/pages/
!/utils/

# Ambientes e artefatos Python
.venv/
__pycache__/
*.pyc
/utils/__pycache__/

# Logs e bancos locais
*.log
logs/
*.sqlite

# Nenhum parquet deve subir
*.parquet

# Artefatos gerados em historia devem ficar fora do repo
historia/cnpj_cache.json
historia/*.csv
historia/*.xlsx
historia/*.xls
historia/*.pdf
historia/*.parquet
historia/**/*.csv
historia/**/*.xlsx
historia/**/*.xls
historia/**/*.pdf
historia/**/*.parquet
